# Copy this to terraform.tfvars and fill in real values.
# terraform.tfvars is gitignored — never commit it.

aws_region      = "us-east-1"
public_key_path = "~/.ssh/id_rsa.pub"

# Git repo URL — for private repos use a GitHub personal access token:
# "https://<TOKEN>@github.com/your-org/your-repo.git"
repo_url = "https://github.com/your-org/your-repo.git"

# Domain you own, e.g. "app.yourdomain.com"
# After apply, point its A record to the output public_ip
domain      = "app.yourdomain.com"
admin_email = "you@example.com"  # Used for ZeroSSL ACME cert registration

# Twilio — from console.twilio.com
twilio_account_sid  = "ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
twilio_auth_token   = "your_twilio_auth_token"
twilio_phone_number = "+15551234567"

# Google AI Studio — aistudio.google.com/apikey
gemini_api_key = "your_gemini_api_key"
